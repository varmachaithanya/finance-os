DATABASE_URL=postgresql://financeosuser:financeospass@localhost:5432/financeosdb
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REPORTS_DIR=./reports
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata

# SMTP (email sending)
# Local dev: use Mailpit (localhost:1025) — no auth needed, web UI at http://localhost:8025
# Production: use Gmail SMTP (smtp.gmail.com:587) with an app password
# Note: Railway blocks outbound SMTP — use RESEND_API_KEY instead for Railway deployments
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@arthya.app

EMAIL_FROM_NAME=Arthya
# Resend (HTTP email API — recommended for Railway)
# Get an API key at https://resend.com
# When RESEND_API_KEY is set, it takes priority over SMTP
RESEND_API_KEY=

# Frontend URL (used in password reset email links)
FRONTEND_URL=http://localhost:5173

# Email config (alternative config style)
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-digit-app-password
MAIL_FROM=your-gmail@gmail.com
MAIL_FROM_NAME=Arthya
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
