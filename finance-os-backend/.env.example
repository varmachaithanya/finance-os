DATABASE_URL=postgresql://financeosuser:financeospass@localhost:5432/financeosdb
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REPORTS_DIR=./reports
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata

# SMTP (email sending)
# Local dev: use Mailpit (localhost:1025) — no auth needed, web UI at http://localhost:8025
# Production: use Gmail SMTP (smtp.gmail.com:587) with an app password
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@wealthwise.app
EMAIL_FROM_NAME=WealthWise

# Frontend URL (used in password reset email links)
FRONTEND_URL=http://localhost:5173
